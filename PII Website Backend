});

document.querySelectorAll('.nav-item').forEach(function(item) {
  item.addEventListener('click', function() {
    navigate(this.getAttribute('data-page'));
  });
});

function navigate(page) {
  document.querySelectorAll('.nav-item').forEach(function(n) { n.classList.remove('active'); });
  var navItem = document.querySelector('.nav-item[data-page="'+page+'"]');
  if (navItem) navItem.classList.add('active');
  document.querySelectorAll('.page').forEach(function(p) { p.classList.remove('active'); });
  var pg = document.getElementById('page-'+page);
  if (pg) pg.classList.add('active');
  var labels = {
    dashboard:'Dashboard', research:'Research & Publications', programs:'Programs',
    hyperion:'Hyperion', carousel:'Hero Carousel', conference:'Change.Enabled',
    affiliates:'Affiliates & Partners', focusareas:'Focus Areas', stats:'Impact Stats',
    media:'Media Library', users:'Users & Access', settings:'Settings'
  };
  document.getElementById('current-page-label').textContent = labels[page] || page;
}

function showToast(msg) {
  var t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(function() { t.classList.remove('show'); }, 2500);
}

function filterTable(input, tbodyId) {
  var q = input.value.toLowerCase();
  var rows = document.getElementById(tbodyId).querySelectorAll('tr');
  rows.forEach(function(row) {
    row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
  });
}

function openPanel(type) {
  var t = document.getElementById('panel-title-text');
  if (type === 'new-research') t.textContent = 'New Publication';
  if (type === 'edit-research') t.textContent = 'Edit Publication';
  document.getElementById('panel-bg').classList.add('open');
  document.getElementById('slide-panel').classList.add('open');
}
function closePanel() {
  document.getElementById('panel-bg').classList.remove('open');
  document.getElementById('slide-panel').classList.remove('open');
}
function openPanelProg(type) {
  document.getElementById('panel-prog-title').textContent = type === 'new-program' ? 'New Program' : 'Edit Program';
  document.getElementById('panel-bg-prog').classList.add('open');
  document.getElementById('slide-panel-prog').classList.add('open');
}
function closePanelProg() {
  document.getElementById('panel-bg-prog').classList.remove('open');
  document.getElementById('slide-panel-prog').classList.remove('open');
}

document.querySelector('.nav-item[data-page="programs"]') && document.querySelector('.nav-item[data-page="programs"]').addEventListener('click', function(){});

document.querySelectorAll('[onclick*="openPanel(\'new-program\')"]').length === 0 && document.querySelectorAll('[onclick*="openPanel(\'edit-program\')"]').forEach(function(el){
  el.setAttribute('onclick', "openPanelProg('edit-program')");
});
document.querySelectorAll('#page-programs .btn-primary').forEach(function(el) {
  el.setAttribute('onclick', "openPanelProg('new-program')");
});

(async function() {
  try {
    var sess = await window.storage.get('pii_session');
    if (sess && sess.value) {
      var data = JSON.parse(sess.value);
      if (data.email === SUPERADMIN_EMAIL) {
        document.getElementById('login-screen').style.display = 'none';
        document.getElementById('app-shell').style.display = 'flex';
        document.getElementById('topbar-user').textContent = 'Khahlil Louisy';
      }
    }
  } catch(e) {}
})();
</script>
