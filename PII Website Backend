
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --ink:#0e0e0c;--ink-mid:#3a3a36;--ink-muted:#7a7a72;
  --paper:#faf9f5;--paper-warm:#f3f0e8;
  --accent:#c8401e;--accent-light:#f5ede9;
  --rule:rgba(14,14,12,0.1);
  --sidebar:220px;
  --serif:'Playfair Display',Georgia,serif;
  --sans:'DM Sans',system-ui,sans-serif;
  --mono:'DM Mono',monospace;
}
body{font-family:var(--sans);background:var(--paper);color:var(--ink);font-size:14px;min-height:100vh}

/* LOGIN */
#login-screen{min-height:600px;display:flex;align-items:center;justify-content:center;background:var(--paper)}
.login-box{width:380px;background:#fff;border:1px solid var(--rule);padding:2.5rem}
.login-logo{display:flex;align-items:center;gap:10px;margin-bottom:2rem}
.login-mark{width:32px;height:32px;background:var(--ink);border-radius:50%;display:flex;align-items:center;justify-content:center}
.login-title{font-family:var(--serif);font-size:16px;font-weight:700;line-height:1.2}
.login-title span{display:block;font-family:var(--sans);font-size:11px;font-weight:400;color:var(--ink-muted);letter-spacing:0.06em;text-transform:uppercase}
.login-box h2{font-family:var(--serif);font-size:1.5rem;font-weight:700;margin-bottom:0.4rem}
.login-box p{font-size:12px;color:var(--ink-muted);margin-bottom:2rem}
.form-field{margin-bottom:1.2rem}
.form-field label{display:block;font-size:11px;font-weight:500;letter-spacing:0.06em;text-transform:uppercase;color:var(--ink-mid);margin-bottom:0.5rem}
.form-field input{width:100%;padding:10px 12px;border:1px solid var(--rule);background:#fff;font-family:var(--sans);font-size:14px;color:var(--ink);outline:none;transition:border-color .2s}
.form-field input:focus{border-color:var(--accent)}
.login-btn{width:100%;background:var(--ink);color:#fff;border:none;padding:12px;font-family:var(--sans);font-size:13px;font-weight:500;letter-spacing:0.06em;text-transform:uppercase;cursor:pointer;transition:background .2s;margin-top:0.5rem}
.login-btn:hover{background:var(--accent)}
.login-error{background:#fff0ed;border:1px solid rgba(200,64,30,0.3);color:var(--accent);font-size:12px;padding:10px 12px;margin-top:1rem;display:none}

/* APP SHELL */
#app-shell{display:none;min-height:100vh;flex-direction:column}
.topbar{height:52px;background:#fff;border-bottom:1px solid var(--rule);display:flex;align-items:center;justify-content:space-between;padding:0 1.5rem;position:sticky;top:0;z-index:50}
.topbar-left{display:flex;align-items:center;gap:10px}
.topbar-mark{width:26px;height:26px;background:var(--ink);border-radius:50%;display:flex;align-items:center;justify-content:center}
.topbar-name{font-family:var(--serif);font-size:13px;font-weight:700}
.topbar-right{display:flex;align-items:center;gap:1rem}
.topbar-user{font-size:11px;color:var(--ink-muted)}
.topbar-badge{background:var(--accent);color:#fff;font-size:10px;font-weight:500;letter-spacing:0.06em;text-transform:uppercase;padding:3px 8px}
.logout-btn{background:none;border:1px solid var(--rule);padding:5px 12px;font-size:11px;font-weight:500;letter-spacing:0.06em;text-transform:uppercase;color:var(--ink-mid);cursor:pointer;transition:all .2s}
.logout-btn:hover{border-color:var(--accent);color:var(--accent)}

.shell-body{display:flex;flex:1}
.sidebar{width:var(--sidebar);background:#fff;border-right:1px solid var(--rule);padding:1.2rem 0;flex-shrink:0;min-height:calc(100vh - 52px)}
.sidebar-section{font-size:10px;letter-spacing:0.1em;text-transform:uppercase;color:var(--ink-muted);padding:0 1.2rem;margin:1.2rem 0 0.5rem}
.nav-item{display:flex;align-items:center;gap:8px;padding:8px 1.2rem;font-size:13px;color:var(--ink-mid);cursor:pointer;transition:all .15s;border-left:2px solid transparent}
.nav-item:hover{background:var(--paper-warm);color:var(--ink)}
.nav-item.active{background:var(--accent-light);color:var(--accent);border-left-color:var(--accent);font-weight:500}
.nav-item i{font-size:16px;opacity:0.7}
.nav-item.active i{opacity:1}

.main{flex:1;padding:2rem;overflow-x:hidden}
.page{display:none}
.page.active{display:block}

/* PAGE HEADERS */
.page-header{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:2rem;padding-bottom:1.5rem;border-bottom:1px solid var(--rule)}
.page-title{font-family:var(--serif);font-size:1.6rem;font-weight:700;line-height:1.2}
.page-sub{font-size:12px;color:var(--ink-muted);margin-top:0.3rem}
.btn{display:inline-flex;align-items:center;gap:6px;padding:9px 18px;font-size:12px;font-weight:500;letter-spacing:0.05em;text-transform:uppercase;cursor:pointer;border:none;transition:all .2s;font-family:var(--sans)}
.btn-primary{background:var(--ink);color:#fff}
.btn-primary:hover{background:var(--accent)}
.btn-secondary{background:#fff;border:1px solid var(--rule);color:var(--ink-mid)}
.btn-secondary:hover{border-color:var(--ink);color:var(--ink)}
.btn-danger{background:#fff;border:1px solid rgba(200,64,30,0.3);color:var(--accent)}
.btn-danger:hover{background:var(--accent-light)}
.btn-sm{padding:6px 12px;font-size:11px}

/* STATS ROW */
.stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin-bottom:2rem}
.stat-card{background:#fff;border:1px solid var(--rule);padding:1.25rem}
.stat-card-label{font-size:11px;letter-spacing:0.06em;text-transform:uppercase;color:var(--ink-muted);margin-bottom:0.5rem}
.stat-card-num{font-family:var(--serif);font-size:2rem;font-weight:700;color:var(--ink);line-height:1}
.stat-card-num span{color:var(--accent)}
.stat-card-sub{font-size:11px;color:var(--ink-muted);margin-top:0.4rem}

/* TABLES */
.table-wrap{background:#fff;border:1px solid var(--rule);overflow:hidden}
.table-toolbar{display:flex;align-items:center;justify-content:space-between;padding:1rem 1.25rem;border-bottom:1px solid var(--rule)}
.search-box{display:flex;align-items:center;gap:8px;background:var(--paper);border:1px solid var(--rule);padding:6px 12px;width:220px}
.search-box i{font-size:15px;color:var(--ink-muted)}
.search-box input{border:none;background:none;font-size:13px;color:var(--ink);outline:none;width:100%;font-family:var(--sans)}
table{width:100%;border-collapse:collapse}
th{padding:10px 1.25rem;text-align:left;font-size:11px;letter-spacing:0.06em;text-transform:uppercase;color:var(--ink-muted);border-bottom:1px solid var(--rule);background:var(--paper);font-weight:500}
td{padding:12px 1.25rem;font-size:13px;border-bottom:1px solid var(--rule)}
tr:last-child td{border-bottom:none}
tr:hover td{background:var(--paper-warm)}
.badge{display:inline-block;font-size:10px;font-weight:500;letter-spacing:0.06em;text-transform:uppercase;padding:3px 9px}
.badge-live{background:rgba(15,110,86,0.1);color:#0F6E56}
.badge-draft{background:rgba(136,135,128,0.12);color:#5F5E5A}
.badge-program{background:var(--accent-light);color:var(--accent)}
.badge-research{background:rgba(52,122,221,0.1);color:#185FA5}
.badge-admin{background:var(--ink);color:#fff}
.row-actions{display:flex;gap:6px}

/* FORMS */
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem}
.form-grid.full{grid-template-columns:1fr}
.field{margin-bottom:1.25rem}
.field label{display:block;font-size:11px;font-weight:500;letter-spacing:0.06em;text-transform:uppercase;color:var(--ink-mid);margin-bottom:0.5rem}
.field input,.field select,.field textarea{width:100%;padding:9px 12px;border:1px solid var(--rule);background:#fff;font-family:var(--sans);font-size:13px;color:var(--ink);outline:none;transition:border-color .2s;resize:vertical}
.field input:focus,.field select:focus,.field textarea:focus{border-color:var(--accent)}
.field textarea{min-height:100px}
.field-hint{font-size:11px;color:var(--ink-muted);margin-top:0.35rem}
.form-section{background:#fff;border:1px solid var(--rule);padding:1.5rem;margin-bottom:1.5rem}
.form-section-title{font-size:12px;font-weight:500;letter-spacing:0.06em;text-transform:uppercase;color:var(--ink-mid);margin-bottom:1.25rem;padding-bottom:0.75rem;border-bottom:1px solid var(--rule)}
.toggle{display:flex;align-items:center;gap:10px;cursor:pointer}
.toggle-track{width:36px;height:20px;background:var(--rule);border-radius:10px;position:relative;transition:background .2s}
.toggle-track.on{background:var(--ink)}
.toggle-thumb{width:14px;height:14px;background:#fff;border-radius:50%;position:absolute;top:3px;left:3px;transition:left .2s}
.toggle-track.on .toggle-thumb{left:19px}
.toggle-label{font-size:13px;color:var(--ink-mid)}

/* MODAL */
.modal-bg{position:fixed;inset:0;background:rgba(14,14,12,0.5);display:flex;align-items:center;justify-content:center;z-index:200;display:none}
.modal-bg.open{display:flex}
.modal{background:#fff;width:520px;max-height:80vh;overflow-y:auto;border:1px solid var(--rule)}
.modal-header{display:flex;align-items:center;justify-content:space-between;padding:1.25rem 1.5rem;border-bottom:1px solid var(--rule);position:sticky;top:0;background:#fff;z-index:1}
.modal-title{font-family:var(--serif);font-size:1.1rem;font-weight:700}
.modal-close{background:none;border:none;cursor:pointer;font-size:18px;color:var(--ink-muted);line-height:1}
.modal-body{padding:1.5rem}
.modal-footer{padding:1rem 1.5rem;border-top:1px solid var(--rule);display:flex;gap:0.75rem;justify-content:flex-end;position:sticky;bottom:0;background:#fff}

/* ACTIVITY */
.activity-feed{display:flex;flex-direction:column;gap:0}
.activity-item{display:flex;gap:1rem;padding:1rem 1.25rem;border-bottom:1px solid var(--rule);align-items:flex-start}
.activity-item:last-child{border-bottom:none}
.activity-icon{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:14px}
.ai-edit{background:rgba(52,122,221,0.1);color:#185FA5}
.ai-pub{background:rgba(15,110,86,0.1);color:#0F6E56}
.ai-new{background:var(--accent-light);color:var(--accent)}
.activity-text{font-size:13px;color:var(--ink-mid);line-height:1.5}
.activity-text strong{color:var(--ink);font-weight:500}
.activity-time{font-size:11px;color:var(--ink-muted);margin-top:0.2rem;font-family:var(--mono)}

/* SETTINGS */
.settings-grid{display:grid;grid-template-columns:1fr 2fr;gap:2rem}
.settings-nav{display:flex;flex-direction:column;gap:0}
.snav-item{padding:10px 1rem;font-size:13px;color:var(--ink-mid);cursor:pointer;border-left:2px solid transparent;transition:all .15s}
.snav-item:hover{background:var(--paper-warm);color:var(--ink)}
.snav-item.active{background:var(--accent-light);color:var(--accent);border-left-color:var(--accent);font-weight:500}

/* TOAST */
.toast{position:fixed;bottom:1.5rem;right:1.5rem;background:var(--ink);color:#fff;padding:12px 20px;font-size:13px;font-weight:500;z-index:999;opacity:0;transform:translateY(10px);transition:all .3s;pointer-events:none}
.toast.show{opacity:1;transform:translateY(0)}

/* SLIDE-IN PANEL */
.panel-bg{position:fixed;inset:0;background:rgba(14,14,12,0.4);z-index:150;display:none}
.panel-bg.open{display:block}
.panel{position:fixed;right:0;top:0;bottom:0;width:560px;background:#fff;border-left:1px solid var(--rule);z-index:151;overflow-y:auto;transform:translateX(100%);transition:transform .3s}
.panel.open{transform:translateX(0)}
.panel-header{display:flex;align-items:center;justify-content:space-between;padding:1.25rem 1.5rem;border-bottom:1px solid var(--rule);position:sticky;top:0;background:#fff;z-index:1}
.panel-title{font-family:var(--serif);font-size:1.1rem;font-weight:700}
.panel-body{padding:1.5rem}
.panel-footer{padding:1rem 1.5rem;border-top:1px solid var(--rule);display:flex;gap:0.75rem;justify-content:flex-end;position:sticky;bottom:0;background:#fff}
</style>

